{
  "name": "workplace-budgeting",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel --aggregate-output dev",
    "dev:web": "pnpm --filter @kazibudget/web dev",
    "dev:backend": "pnpm --filter @kazibudget/backend dev",
    "build": "pnpm --filter @kazibudget/web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test:unit": "pnpm -r test:unit",
    "check": "pnpm lint && pnpm typecheck && pnpm test:unit"
  }
}
